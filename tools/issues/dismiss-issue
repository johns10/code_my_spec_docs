#!/bin/bash
# Dismiss an incoming issue with a reason.
# Usage: dismiss-issue <id> <reason>
#
# Calls the local CodeMySpec server (no auth needed).
set -euo pipefail

ID="${1:?Usage: dismiss-issue <id> <reason>}"
REASON="${2:?Usage: dismiss-issue <id> <reason>}"
PORT="${CODEMYSPEC_PORT:-4002}"

JSON=$(jq -n --arg reason "$REASON" '{reason: $reason}')

curl -sf -X POST "http://localhost:${PORT}/api/issues/${ID}/dismiss" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: ${PWD}" \
  -d "$JSON"
