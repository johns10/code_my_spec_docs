#!/bin/bash
# Accept an incoming issue (transition to accepted status).
# Usage: accept-issue <id>
#
# Calls the local CodeMySpec server (no auth needed).
set -euo pipefail

ID="${1:?Usage: accept-issue <id>}"
PORT="${CODEMYSPEC_PORT:-4002}"

curl -sf -X POST "http://localhost:${PORT}/api/issues/${ID}/accept" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: ${PWD}"
