#!/bin/bash
# Resolve an accepted issue with a resolution description.
# Usage: resolve-issue <id> <resolution>
#
# Calls the local CodeMySpec server (no auth needed).
set -euo pipefail

ID="${1:?Usage: resolve-issue <id> <resolution>}"
RESOLUTION="${2:?Usage: resolve-issue <id> <resolution>}"
PORT="${CODEMYSPEC_PORT:-4002}"

JSON=$(jq -n --arg resolution "$RESOLUTION" '{resolution: $resolution}')

curl -sf -X POST "http://localhost:${PORT}/api/issues/${ID}/resolve" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: ${PWD}" \
  -d "$JSON"
