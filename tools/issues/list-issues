#!/bin/bash
# List issues for the current project with optional filters.
# Usage: list-issues [--status STATUS] [--severity SEVERITY] [--story STORY_ID] [--scope SCOPE]
#
# Options:
#   --status    Filter by status (incoming, accepted, dismissed, resolved)
#   --severity  Filter by minimum severity (critical, high, medium, low, info)
#   --story     Filter by story ID
#   --scope     Filter by scope (app, qa, docs)
#
# Calls the local CodeMySpec server (no auth needed).
set -euo pipefail

PORT="${CODEMYSPEC_PORT:-4002}"
QUERY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status)  QUERY="${QUERY:+${QUERY}&}status=$2"; shift 2 ;;
    --severity) QUERY="${QUERY:+${QUERY}&}severity=$2"; shift 2 ;;
    --story)   QUERY="${QUERY:+${QUERY}&}story_id=$2"; shift 2 ;;
    --scope)   QUERY="${QUERY:+${QUERY}&}scope=$2"; shift 2 ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

URL="http://localhost:${PORT}/api/issues"
if [[ -n "$QUERY" ]]; then
  URL="${URL}?${QUERY}"
fi

curl -sf "$URL" -H "X-Working-Dir: ${PWD}"
