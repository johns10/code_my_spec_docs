#!/bin/bash
# Analyzes story-component linkage for the current project.
# Usage: story-linkage
#
# Calls the local CodeMySpec server (no auth needed).
# Requires the server to be running on localhost:4003.
set -euo pipefail

PORT="${CODEMYSPEC_PORT:-4003}"

curl -sf "http://localhost:${PORT}/api/stories/linkage" \
  -H "X-Working-Dir: ${PWD}"
